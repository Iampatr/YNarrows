<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/transparent"
    android:orientation="vertical">

    <View
        android:layout_width="match_parent"
        android:layout_height="720px" />

    <FrameLayout
        android:layout_width="700px"
        android:layout_height="187px"
        android:layout_gravity="start"
        android:background="@drawable/hud_border_layout">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="start"
            android:layout_margin="2px"
            android:orientation="vertical">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top"
                    android:orientation="horizontal">

                <FrameLayout
                    android:layout_width="120px"
                    android:layout_height="110px"
                    android:background="@drawable/inner_fragment_border"
                    android:clipToOutline="true">

                    <ImageView
                        android:id="@+id/intercepted_notification_arrow"
                        android:layout_width="75px"
                        android:layout_height="75px"
                        android:layout_gravity="top|center"
                        android:alpha="0.75"
                        android:contentDescription="@string/Empty" />

                    <TextView
                        android:id="@+id/notification_text_dist"
                        android:layout_width="120px"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="71px"

                        android:text="@string/Empty"
                        android:textColor="@color/white"
                        android:fontFamily="@font/geely_switches"
                        android:textSize="26px"
                        android:alpha="0.70"
                        android:typeface="monospace"
                        android:gravity="center_horizontal"
                        android:singleLine="true" />

                </FrameLayout>

                <FrameLayout
                    android:layout_width="80px"
                    android:layout_height="110px"
                    android:background="@drawable/inner_fragment_border"
                    android:clipToOutline="true">

                    <ImageView
                        android:id="@+id/intercepted_notification_speed"
                        android:layout_width="75px"
                        android:layout_height="75px"
                        android:layout_gravity="top|center"
                        android:alpha="0.75"
                        android:contentDescription="@string/Empty"
                        android:src="@drawable/camera1"
                        android:visibility="invisible" />

                    <TextView
                        android:id="@+id/notification_text_camerad"
                        android:layout_width="120px"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="71px"


                        android:text="@string/Empty"
                        android:textColor="@color/white"
                        android:fontFamily="@font/geely_switches"
                        android:textSize="26px"
                        android:alpha="0.70"
                        android:typeface="monospace"
                        android:gravity="center_horizontal"
                        android:singleLine="true" />

                </FrameLayout>
            </LinearLayout>

            <FrameLayout
                android:layout_width="240px"
                android:layout_height="72px"
                android:background="@drawable/inner_fragment_border"
                android:clipToOutline="true"
                >

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:orientation="horizontal"                    >


                    <TextView
                        android:id="@+id/notification_text_street"
                        android:layout_width="230px"
                        android:layout_height="wrap_content"


                        android:alpha="0.85"
                        android:fontFamily="@font/geely_switches"
                        android:gravity="center_horizontal"
                        android:singleLine="true"
                        android:text="@string/Empty"
                        android:textColor="@color/white"
                        android:textSize="24px"

                        android:typeface="monospace" />

                </LinearLayout>
            </FrameLayout>
        </LinearLayout>
    </FrameLayout>

</LinearLayout>
